{
  "name": "Smart HR Tools",
  "image": "mcr.microsoft.com/devcontainers/java:21",
  "features": {
    "ghcr.io/itsmechlark/features/postgresql:1": {
      "version": "16"
    }
  },
  "containerEnv": {
    "DB_URL": "jdbc:postgresql://localhost:5432/hr_attendance",
    "DB_USERNAME": "postgres",
    "DB_PASSWORD": "password123"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-spring-initializr",
        "vscjava.vscode-spring-boot-dashboard"
      ]
    }
  },
  "postCreateCommand": "sudo service postgresql start && sudo -u postgres psql -c \"ALTER USER postgres PASSWORD 'password123';\" && sudo -u postgres createdb hr_attendance 2>/dev/null; mvn clean install -DskipTests",
  "postStartCommand": "sudo service postgresql start",
  "forwardPorts": [8080, 5432],
  "portsAttributes": {
    "8080": {
      "label": "Spring Boot App",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    }
  }
}
